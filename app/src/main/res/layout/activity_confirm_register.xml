<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ConfirmRegister"
    android:background="@drawable/background">

    <TextView
        android:text="Confirmasi Register"
        android:textSize="35dp"
        android:layout_marginTop="80dp"
        android:textAlignment="center"
        android:layout_marginLeft="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"/>

    <TextView
        android:text="Name"
        android:textSize="30dp"
        android:layout_marginTop="45dp"
        android:textAlignment="center"
        android:layout_marginLeft="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <TextView
            android:layout_marginTop="10dp"
            android:hint="nama"
            android:id="@+id/txtNamaConfirmRegister"
            android:layout_margin="10dp"
            android:textSize="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:text="G-Mail"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginLeft="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <TextView
            android:layout_marginTop="10dp"
            android:hint="email"
            android:id="@+id/txtEmailConfirmRegister"
            android:layout_margin="10dp"
            android:textSize="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:text="Alamat"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginLeft="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <TextView
            android:layout_marginTop="10dp"
            android:hint="alamat"
            android:id="@+id/txtAlamatConfirmRegister"
            android:layout_margin="10dp"
            android:textSize="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:text="No. Telp"
        android:textSize="30dp"
        android:textAlignment="center"
        android:layout_marginLeft="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <TextView
            android:layout_marginTop="10dp"
            android:hint="nomor"
            android:id="@+id/txtNomorConfirmRegister"
            android:layout_margin="10dp"
            android:textSize="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

</LinearLayout>