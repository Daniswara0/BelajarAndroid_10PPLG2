<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".KalkulatorAritmatika"
    android:background="@drawable/background">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="80dp"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:text="Hello, "
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="45dp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/txtUsernameKalkulator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:text="Username"
        android:textAlignment="textStart"
        android:textColor="#FFFFFF"
        android:textSize="45dp"
        android:textStyle="bold"/>

    <TextView
        android:text="Kalkulator Aritmatika"
        android:textSize="35dp"
        android:layout_marginTop="50dp"
        android:textAlignment="center"
        android:layout_marginLeft="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginTop="20dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtAngka1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Angka 1"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="number"/>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtAngka2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Angka 2"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="number"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

    <Button
        android:id="@+id/btnTambah"
        android:text="tambah"
        android:layout_marginLeft="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="20dp"
        android:backgroundTint="#FF6991"
        android:padding="10dp"
        android:elevation="9dp"
        android:translationZ="3dp"/>

    <Button
        android:id="@+id/btnKurang"
        android:text="kurang"
        android:layout_marginLeft="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="20dp"
        android:backgroundTint="#FF6991"
        android:padding="10dp"
        android:elevation="9dp"
        android:translationZ="3dp"/>

    <Button
        android:id="@+id/btnKali"
        android:text="kali"
        android:layout_marginLeft="10dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="20dp"
        android:backgroundTint="#FF6991"
        android:padding="10dp"
        android:elevation="9dp"
        android:translationZ="3dp"/>

    <Button
        android:id="@+id/btnBagi"
        android:layout_marginLeft="10dp"
        android:text="bagi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="20dp"
        android:backgroundTint="#FF6991"
        android:padding="10dp"
        android:elevation="9dp"
        android:translationZ="3dp"/>

   </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <TextView
            android:layout_marginTop="10dp"
            android:hint="Hasil:"
            android:id="@+id/txtHasil"
            android:layout_margin="10dp"
            android:textSize="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnBersihkan"
            android:layout_marginLeft="300dp"
            android:layout_gravity="left"
            android:text="Clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="20dp"
            android:backgroundTint="#FF6991"
            android:padding="10dp"
            android:elevation="9dp"
            android:translationZ="3dp"/>

    </LinearLayout>

</LinearLayout>