<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".Register">

    <TextView
        android:layout_width="293dp"
        android:textStyle="bold"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="160dp"
        android:text="Let's Get Started!"
        android:textSize="35dp"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:textColor="#FFFFFF"
        android:textAlignment="center"
        android:layout_marginBottom="20dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtNamaRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your Name"
            android:background="@android:color/transparent"
            android:padding="14dp"/>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtEmailRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Gmail"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="textEmailAddress"/>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtAlamatRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Address"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="textPostalAddress"/>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtNomorRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Number"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="number"/>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true">

        <EditText
            android:id="@+id/edtPasswordRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="textPassword"/>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        android:layout_marginBottom="15dp">

        <EditText
            android:id="@+id/edtConfirmPasswordRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirm Password"
            android:background="@android:color/transparent"
            android:padding="14dp"
            android:inputType="textPassword"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnNext"
            android:layout_marginLeft="300dp"
            android:layout_gravity="left"
            android:text="Next"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="20dp"
            android:backgroundTint="#FF6991"
            android:padding="10dp"
            android:elevation="9dp"
            android:translationZ="3dp"/>

    </LinearLayout>

</LinearLayout>