<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".XLoginPage"
    android:background="@drawable/background_x">


    <ImageView
        android:id="@+id/imgXLogo"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="36dp"
        android:src="@drawable/logo_x"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtSignIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="144dp"
        android:text="𝗦𝗶𝗴𝗻 𝗶𝗻 𝘁𝗼 𝗫"
        android:textColor="#ffffff"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imgXLogo" />

    <FrameLayout
        android:id="@+id/frameGoogle"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/txtSignIn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="#FFFF"
            android:text="Sign in with Google"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:paddingStart="50dp"
            android:textSize="17sp"/>

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="60dp"
            android:src="@drawable/img_3" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/frameApple"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/frameGoogle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnApple"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="#FFFF"
            android:text="Sign in with Apple"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:paddingStart="50dp"
            android:textSize="17sp" />

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="60dp"
            android:src="@drawable/img_4" />

    </FrameLayout>

    <TextView
        android:layout_marginLeft="50dp"
        android:id="@+id/txtOr1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:alpha="0.5"
        android:text="─────────"
        android:textColor="#ffff"
        android:textSize="20dp"
        app:layout_constraintEnd_toStartOf="@+id/txtOr2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/frameApple" />

    <TextView
        android:id="@+id/txtOr2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="or"
        android:textColor="#ffff"
        android:textSize="20dp"
        app:layout_constraintEnd_toEndOf="@+id/txtOr3"
        app:layout_constraintStart_toStartOf="@+id/txtOr1"
        app:layout_constraintTop_toBottomOf="@+id/frameApple" />

    <TextView
        android:layout_marginRight="50dp"
        android:alpha="0.5"
        android:id="@+id/txtOr3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="─────────"
        android:textColor="#ffff"
        android:textSize="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/txtOr2"
        app:layout_constraintTop_toBottomOf="@+id/frameApple" />

    <com.google.android.material.card.MaterialCardView
        android:alpha="0.5"
        android:id="@+id/cardUsernameX"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toTopOf="@id/txtOr2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardCornerRadius="0dp"
        app:cardBackgroundColor="#000000"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="1dp"
        app:cardElevation="0dp">

        <EditText
            android:id="@+id/edtUsernameX"
            android:layout_width="311dp"
            android:layout_height="match_parent"
            android:background="@null"
            android:hint="Phone, email, or username"
            android:inputType="text"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA" />

    </com.google.android.material.card.MaterialCardView>

    <Button
        android:id="@+id/btnNextX"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="20dp"
        android:text="Next"
        android:textColor="#000000"
        android:backgroundTint="#FFFF"
        android:textSize="17sp"
        app:layout_constraintTop_toBottomOf="@id/cardUsernameX"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForgotX"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginTop="15dp"
        android:text="Forgot password?"
        android:textColor="#FFFFFF"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="#FFFFFF"
        android:textSize="15dp"
        app:strokeWidth="1dp"
        app:cornerRadius="50dp"
        app:layout_constraintTop_toBottomOf="@id/btnNextX"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtAskAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginRight="50dp"
        android:alpha="0.5"
        android:text="Don't have an account?"
        android:textColor="#ffff"
        android:textSize="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.267"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnForgotX" />

    <TextView
        android:id="@+id/txtSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginRight="50dp"
        android:text="Sign Up"
        android:textColor="#1E90FF"
        android:textSize="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.039"
        app:layout_constraintStart_toEndOf="@+id/txtAskAccount"
        app:layout_constraintTop_toBottomOf="@+id/btnForgotX" />


</androidx.constraintlayout.widget.ConstraintLayout>