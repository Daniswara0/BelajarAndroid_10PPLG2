<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PersegiPanjang"
    android:background="@drawable/background"
    android:padding="30dp">

    <TextView
        android:id="@+id/tvPersegiPanjang"
        android:layout_width="293dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="164dp"
        android:shadowColor="#B84A4A"
        android:shadowDx="4"
        android:shadowDy="3"
        android:shadowRadius="4"
        android:text="Persegi Panjang"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPanjang"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintEnd_toStartOf="@+id/cardLebar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPersegiPanjang">

        <EditText
            android:id="@+id/edtPanjang"
            android:layout_width="124dp"
            android:layout_height="82dp"
            android:background="@android:color/transparent"
            android:hint="Panjang"
            android:padding="14dp" />
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardLebar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="44dp"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/cardPanjang"
        app:layout_constraintTop_toBottomOf="@id/tvPersegiPanjang">

        <EditText
            android:id="@+id/edtLebar"
            android:layout_width="135dp"
            android:layout_height="82dp"
            android:background="@android:color/transparent"
            android:hint="Lebar"
            android:padding="14dp" />
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnLuas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="#FF6991"
        android:elevation="9dp"
        android:padding="10dp"
        android:text="Luas"
        android:textSize="20sp"
        android:textStyle="bold"
        android:translationZ="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardLebar" />

    <Button
        android:id="@+id/btnKeliling"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="#FF6991"
        android:elevation="9dp"
        android:padding="10dp"
        android:text="Keliling"
        android:textSize="20sp"
        android:textStyle="bold"
        android:translationZ="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnLuas"/>

    <androidx.cardview.widget.CardView
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/cardHasilPersegiPanjang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="12dp"
        android:layout_marginLeft="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="10dp"
        app:cardUseCompatPadding="true">

        <TextView
            android:layout_marginTop="10dp"
            android:hint="Hasil:"
            android:id="@+id/txtHasil"
            android:layout_margin="10dp"
            android:textSize="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"/>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>